# ---------------------------------------------------------------------------
# Zoom 録音DL — 認証（いずれか1つ。優先順: CDP > storage_state > cookies > メール）
# ---------------------------------------------------------------------------

# A. 既存ChromeにCDP接続（ログイン済みCookieをそのまま利用・推奨）
#    Chrome を次で起動してから実行:
#      Windows: "C:\...\chrome.exe" --remote-debugging-port=9222
#    WSL から Windows Chrome へ接続する例:
#      ZOOM_CDP_URL=http://host.docker.internal:9222
#      または Windows の IP: ZOOM_CDP_URL=http://192.168.x.x:9222
# ZOOM_CDP_URL=http://127.0.0.1:9222

# B. Playwright storage_state（SSOは手動ログイン後に保存）
#    初回: .venv/bin/python src/zoom_recording_downloader.py --save-auth
#    保存先を変える場合:
# ZOOM_STORAGE_STATE=/absolute/path/to/zoom_auth.json
# 未指定で 07_automation/zoom_auth.json が存在すれば自動利用

# C. Cookie JSON（Playwright形式の配列。HttpOnly が取れない場合は A/B を推奨）
# ZOOM_COOKIES_FILE=/absolute/path/to/cookies.json

# D. メール/パスワード（Zoomのメールログインのみ。SSO不可）
# ZOOM_EMAIL=your_email@example.com
# ZOOM_PASSWORD=your_password

# ---------------------------------------------------------------------------
# その他
# ---------------------------------------------------------------------------

# ZOOM_DOWNLOAD_DIR=../../02_data_raw/zoom_recordings
# ZOOM_FROM_DATE=2026-04-01
# ZOOM_TO_DATE=2026-04-27
# ZOOM_HEADLESS=false
