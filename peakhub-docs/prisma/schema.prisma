generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AppRole {
  manager
  director
}

enum KpiGranularity {
  week
  month
}

enum KpiScopeType {
  company
  division
  project
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  divisions Division[]
  projects  Project[]
  kpis      KpiDefinition[]
  members   CompanyMember[]
}

model Division {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects  Project[]
  kpis      KpiDefinition[]

  @@index([companyId])
}

model Project {
  id         String   @id @default(cuid())
  companyId  String
  divisionId String?
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  division   Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  kpis       KpiDefinition[]
  members    ProjectMember[]

  @@index([companyId])
  @@index([divisionId])
}

model KpiDefinition {
  id          String         @id @default(cuid())
  code        String
  name        String
  unit        String
  formula     String
  granularity KpiGranularity
  notes       String
  scopeType   KpiScopeType

  companyId   String?
  divisionId  String?
  projectId   String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company     Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  division    Division?      @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actuals     KpiActual[]

  @@unique([scopeType, companyId, divisionId, projectId, code])
  @@index([companyId])
  @@index([divisionId])
  @@index([projectId])
}

model KpiActual {
  id               String   @id @default(cuid())
  kpiDefinitionId  String

  periodStart      DateTime
  periodType       KpiGranularity

  value            Float
  sourceRef        String
  fetchedAt        DateTime

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kpiDefinition    KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)

  @@index([kpiDefinitionId])
  @@index([periodType, periodStart])
  @@unique([kpiDefinitionId, periodType, periodStart, sourceRef])
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  companyRoles  CompanyMember[]
  projectRoles  ProjectMember[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, role])
  @@index([companyId])
  @@index([userId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

