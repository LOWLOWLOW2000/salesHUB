# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# Prisma / PostgreSQL
DATABASE_URL="postgresql://saleshub:saleshub@localhost:5433/saleshub?schema=public"

# NextAuth (generate secret e.g. openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional if you use Credentials only — but then set ENABLE_CREDENTIALS_AUTH)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_OAUTH_SCOPES="openid email profile"
# GOOGLE_REQUIRED_SCOPES=""

# First GM user email (optional; gets CompanyMember gm on sign-in)
GM_EMAIL=""

# Email + password login (true / 1 / yes)
# ENABLE_CREDENTIALS_AUTH="true"

# Optional HTTP Basic in front of the app (see src/lib/auth/basic.ts)
# BASIC_AUTH_USER=""
# BASIC_AUTH_PASS=""
# BASIC_AUTH_REALM="salesHUB"
