generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AppRole {
  manager
  director
}

enum WorkspaceType {
  client
  auto_squad
}

enum WorkspaceRole {
  owner
  director
  member
  viewer
  is
  fs
  manager
}

enum KpiGranularity {
  week
  month
}

enum KpiScopeType {
  company
  division
  project
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  divisions Division[]
  projects  Project[]
  kpis      KpiDefinition[]
  members   CompanyMember[]
}

model Division {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects  Project[]
  kpis      KpiDefinition[]

  @@index([companyId])
}

model Project {
  id         String   @id @default(cuid())
  companyId  String
  divisionId String?
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  division   Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  kpis       KpiDefinition[]
  members    ProjectMember[]
  dailyReports DailyReport[]
  scripts    ProjectScript[]
  dealStages DealStage[]
  aiSuggestions AiSuggestion[]

  @@index([companyId])
  @@index([divisionId])
}

model DailyReport {
  id                String   @id @default(cuid())
  projectId         String
  userId            String
  date              DateTime

  callCount         Int      @default(0)
  connectCount      Int      @default(0)
  receptionNgCount  Int      @default(0)
  keymanNgCount     Int      @default(0)
  materialSentCount Int      @default(0)
  appointmentCount  Int      @default(0)

  callMinutes       Int      @default(0)
  totalMinutes      Int      @default(0)
  notes             String   @default("")
  callSlots         String   @default("")
  receptionNgReasons String @default("")
  keymanNgReasons   String   @default("")
  appointmentReasonTags String @default("")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, date])
  @@index([projectId, date])
  @@index([userId])
}

model ProjectScript {
  id        String   @id @default(cuid())
  projectId String
  category  String
  seq       Int
  title     String
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, category])
  @@index([projectId, category, seq])
}

model DealStage {
  id              String    @id @default(cuid())
  projectId       String
  accountName     String
  contactName     String    @default("")
  stage           String
  source          String    @default("")
  amount          Int?
  appointmentDate DateTime?
  closedAt        DateTime?
  lostReason      String    @default("")
  wonReason       String    @default("")
  notes           String    @default("")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, stage])
  @@index([projectId, appointmentDate])
}

model AiSuggestion {
  id            String   @id @default(cuid())
  projectId     String
  periodStart   DateTime
  periodEnd     DateTime
  promptSummary String
  suggestion    String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model KpiDefinition {
  id          String         @id @default(cuid())
  code        String
  name        String
  unit        String
  formula     String
  granularity KpiGranularity
  notes       String
  scopeType   KpiScopeType

  companyId   String?
  divisionId  String?
  projectId   String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company     Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  division    Division?      @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actuals     KpiActual[]

  @@unique([scopeType, companyId, divisionId, projectId, code])
  @@index([companyId])
  @@index([divisionId])
  @@index([projectId])
}

model KpiActual {
  id               String   @id @default(cuid())
  kpiDefinitionId  String

  periodStart      DateTime
  periodType       KpiGranularity

  value            Float
  sourceRef        String
  fetchedAt        DateTime

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kpiDefinition    KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)

  @@index([kpiDefinitionId])
  @@index([periodType, periodStart])
  @@unique([kpiDefinitionId, periodType, periodStart, sourceRef])
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  onboardingCompletedAt DateTime?
  primaryWorkspaceId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  companyRoles  CompanyMember[]
  projectRoles  ProjectMember[]
  workspaceRoles WorkspaceMember[]
  dailyReports  DailyReport[]

  primaryWorkspace Workspace? @relation("PrimaryWorkspace", fields: [primaryWorkspaceId], references: [id], onDelete: SetNull)
}

model Workspace {
  id        String        @id @default(cuid())
  type      WorkspaceType
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members   WorkspaceMember[]
  primaryForUsers User[]  @relation("PrimaryWorkspace")

  @@unique([type, name])
  @@index([type])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, role])
  @@index([companyId])
  @@index([userId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

