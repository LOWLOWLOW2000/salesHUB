# Copy to .env.local and fill values:
#   cp .env.example .env.local
#
# Prisma CLI reads `.env` by default. For local SQLite you can keep a one-line
# `sales_hub/.env` with only DATABASE_URL (gitignored), or pass it inline:
#   DATABASE_URL="file:./dev.db" npx prisma migrate deploy
#
# Relative SQLite URLs are resolved from the folder that contains schema.prisma
# (sales_hub/prisma/), so use file:./dev.db → sales_hub/prisma/dev.db — not file:./prisma/dev.db.

# SQLite (Prisma) — resolves to sales_hub/prisma/dev.db
# One DATABASE_URL = one SQLite file. Multiple rows in the `Project` table are not
# multiple databases; do not point two env files at two different URLs unless intentional.
DATABASE_URL="file:./dev.db"

# NextAuth (generate a secret for production: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
# Put real values only in `.env.local` (never commit secrets).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: comma/space-separated extra Google scopes
# GOOGLE_OAUTH_SCOPES=openid email profile

# First login / break-glass: must match the Google account email you sign in with
# (case-insensitive). Without this, only emails in DB `AllowedEmail` can sign in
# — and you cannot open /admin/allowed-emails until you are manager or allowed.
MANAGER_EMAIL=
